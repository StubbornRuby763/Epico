generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String
  price       Float
  image       String
  category    Category
  stock       Int
  popularity  Int        @default(0)
  cartItems   CartItem[]
  discount ProductDiscount?
}

model ProductDiscount{
  id        Int     @id @default(autoincrement())
  percent   Int     // Ejemplo: 20 para 20%
  isActive  Boolean @default(true)
  
  product   Product @relation(fields: [productId], references: [id])
  productId Int     @unique 
}


model ShoppingCart {
  id      Int        @id @default(autoincrement())
  monto   Float      @default(0)
  items   CartItem[]
  clients Client[]
}

model CartItem {
  id       Int @id @default(autoincrement())
  quantity Int @default(1)

  // Relaciones
  product   Product @relation(fields: [productId], references: [id])
  productId Int

  shoppingCart   ShoppingCart @relation(fields: [shoppingCartId], references: [id])
  shoppingCartId Int
  @@unique([productId, shoppingCartId])
}

enum Category {
  CONSUME
  INDUSTRIAL
  SERVICES
  DIGITAL
  SUBSCRIPTION
}
model Client {
  id       Int           @id @default(autoincrement())
  user     String        @unique
  password String
  
  // Relación unificada
  cart     ShoppingCart? @relation(fields: [cartId], references: [id])
  cartId   Int?          @unique // Solo este, borra shoppingCartId
  
  image    String
}

model ClientATM {
  id       Int     @id @default(autoincrement())
  user     String  @unique
  password String
  balance  Decimal @default(0.00) @db.Decimal(12, 2)
}
