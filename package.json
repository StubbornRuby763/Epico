{
  "name": "nexusstore",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:build": "npx tsc",
    "dev:watch:build": "npx tsc -w",
    "dev:node": "nodemon --watch dist dist/Bank/backend/index.js",
    "dev:back": "run-p dev:watch:build dev:node",
    "dev:front": "esbuild src/Bank/frontend/login.tsx src/Bank/frontend/dashboard.tsx --bundle --outdir=public/bank --sourcemap --servedir=public",
    "dev:tail": " npx @tailwindcss/cli -i ./src/Bank/input.css -o ./public/bank/output.css ",
    "dev": "run-p dev:back dev:front dev:tail",
    "build:back": "tsc",
    "build:front": "esbuild src/Bank/frontend/index.tsx --bundle --minify --sourcemap --outfile=public/bundle.js",
    "build:tail": "npx @tailwindcss/cli -i ./src/input.css -o ./public/output.css",
    "build": "run-s db:generate build:tail build:front build:back",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "seed": "npx tsx prisma/seed.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tailwindcss/cli": "^4.2.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.400.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^2.12.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prisma": "~6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "imports": {
    "#services/*.js": "./dist/Services/*.js",
    "#store/*.js": "./dist/Store/*.js",
    "#bank/*.js": "./dist/Bank/*.js"
  }
}
