{
  "name": "nexusstore",
  "version": "0.1.0",
  "type": "module",
  "author": "StubbornRuby763",
  "scripts": {
    "// --- COMMON ---": "",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "seed": "npx tsx prisma/seed.ts",
    "check-types": "tsc --noEmit",
    "dev:watch:build": "npx tsc -w --preserveWatchOutput",

    "// --- BANK SCRIPTS ---": "",
    "dev:bank:node": "nodemon --watch dist/Bank/backend --watch dist/Services --delay 1 dist/Bank/backend/index.js",
    "dev:bank:front": "esbuild src/Bank/frontend/login.tsx src/Bank/frontend/dashboard.tsx src/Bank/frontend/loginWith.tsx --bundle --outdir=public/bank --sourcemap ",
    "dev:bank:tail": "npx @tailwindcss/cli -i ./src/Bank/input.css -o ./public/bank/output.css --watch",
    "dev:bank": "run-p dev:watch:build dev:bank:node dev:bank:front dev:bank:tail",
    
    "build:bank:back": "tsc",
    "build:bank:front": "esbuild src/Bank/frontend/login.tsx src/Bank/frontend/dashboard.tsx --bundle --minify --outdir=public/bank",
    "build:bank:tail": "npx @tailwindcss/cli -i ./src/Bank/input.css -o ./public/bank/output.css",

    "// --- STORE SCRIPTS ---": "",
    "dev:store:node": "nodemon --watch dist/Store/backend --watch dist/Services --delay 1 dist/Store/backend/server.js",
    "dev:store:front": "esbuild src/Store/frontend/index.tsx --bundle --outfile=public/store/index.js --loader:.png=file --servedir=public ",
    "dev:store:tail": "npx tailwindcss -i ./src/Store/input.css -o ./public/store/output.css --content ./src/Store/**/*.{js,jsx,ts,tsx} --watch",
    "dev:store": "run-p dev:watch:build dev:store:node dev:store:front dev:store:tail",

    "build:store:front": "esbuild src/Store/frontend/index.tsx --bundle --minify --outdir=public/store --loader:.png=file",
    "build:store:tail": "npx tailwindcss -i ./src/Store/input.css -o ./public/store/output.css --content ./src/Store/**/*.{js,jsx,ts,tsx}",

    "// --- UNIFIED COMMANDS ---": "",
    "dev": "run-p dev:watch:build dev:bank:node dev:bank:front dev:bank:tail dev:store:node dev:store:front dev:store:tail",
    "build": "run-s db:generate build:bank:tail build:bank:front build:store:tail build:store:front build:bank:back",
    "start:bank": "node dist/Bank/backend/index.js",
    "start:store": "node dist/Store/backend/server.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tailwindcss/cli": "^4.2.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.400.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "recharts": "^2.12.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prisma": "~6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "imports": {
    "#services/*.js": "./dist/Services/*.js",
    "#store/*.js": "./dist/Store/*.js",
    "#bank/*.js": "./dist/Bank/*.js"
  }
}
